# Copia este archivo a .env y ajusta los valores.
# En desarrollo local, si el API corre en otro puerto/host:
# REACT_APP_API_URL=http://localhost:3001
#
# En producción (build en el servidor): usa la URL pública SIN /api al final
# (el código añade /api). Ejemplos:
# REACT_APP_API_URL=http://192.168.1.50
# REACT_APP_API_URL=https://sigec.tudominio.com
#
# No uses 127.0.0.1:3001 para builds que consumirán usuarios en otra PC:
# el navegador interpretaría 127.0.0.1 como la máquina del cliente.

REACT_APP_API_URL=http://localhost:3001
