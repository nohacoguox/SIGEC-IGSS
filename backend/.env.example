# Backend — copiar a .env y ajustar (no subir .env al repositorio)

PORT=3001
NODE_ENV=development

# PostgreSQL
# Base: nombre lógico IGSS → identificador en PostgreSQL: igss (minúsculas; convención estándar)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=igss
DB_USER=portal_app
DB_PASSWORD=cambiar_por_contraseña_segura
# Esquema SIGEC-IGSS (Sistema Integral de Gestión de Expedientes de Compras del IGSS)
# Nombre técnico sin guiones: sigec_igss (los guiones en identificadores obligan a comillas en SQL)
DB_SCHEMA=sigec_igss

# true solo en desarrollo / primer arranque; en producción usar false + migraciones
DB_SYNCHRONIZE=true
DB_LOGGING=false

JWT_SECRET=generar_con_openssl_rand_base64_32
